# Copy this file to `.env` and fill in values for local development.

# --- Server ---
PORT=
ORIGIN=
APP_ENV=

# --- PostgreSQL ---
# Requires the PostGIS extension to be enabled on the target database.
DATABASE_URL=
DATABASE_MAX_CONNECTIONS=

# --- Redis ---
REDIS_HOST=
REDIS_PORT=
REDIS_POOL_SIZE=
REDIS_PARTITION=
RECONNECT_MAX_ATTEMPTS=
RECONNECT_DELAY=
DEFAULT_TTL=
DEFAULT_HASH_TTL=
EXP_TTL=
STREAM_READ_COUNT=
REDIS_CLUSTER_ENABLED=
REDIS_CLUSTER_URLS=

# --- Auth / Crypto ---
JWT_SECRETE_KEY=
OTP_API_KEY=

# --- AWS ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET=
KMS_KEY_ID=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Push Notifications ---
GORUSH_URL=

# --- Rate limiting ---
# Comma-separated IPs of trusted reverse proxies (LB, HAProxy). Used by the
# rate-limit middleware to find the real client IP from X-Forwarded-For.
# Leave empty in dev. In prod set to your known ingress IPs.
TRUSTED_PROXIES=
