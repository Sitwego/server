# Copy this file to `.env` and fill in values for local development.

# --- Server ---
PORT=
ORIGIN=
APP_ENV=

# --- PostgreSQL ---
# Requires the PostGIS extension to be enabled on the target database.
DATABASE_URL=
DATABASE_MAX_CONNECTIONS=

# --- Redis ---
REDIS_HOST=
REDIS_PORT=
REDIS_POOL_SIZE=
REDIS_PARTITION=
RECONNECT_MAX_ATTEMPTS=
RECONNECT_DELAY=
DEFAULT_TTL=
DEFAULT_HASH_TTL=
EXP_TTL=
STREAM_READ_COUNT=
REDIS_CLUSTER_ENABLED=
REDIS_CLUSTER_URLS=

# --- Auth / Crypto ---
JWT_SECRETE_KEY=
OTP_API_KEY=

# --- AWS ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET=
KMS_KEY_ID=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Push Notifications ---
GORUSH_URL=

# --- Rate limiting ---
# Comma-separated IPs of trusted reverse proxies (LB, HAProxy). Used by the
# rate-limit middleware to find the real client IP from X-Forwarded-For.
# Leave empty in dev. In prod set to your known ingress IPs.
TRUSTED_PROXIES=

# --- Admin plane (private) ---
# A SECOND listener serving the /admin/* routes (driver verification, billing,
# subscription tools). It is OPT-IN: when ADMIN_INTERNAL_TOKEN is empty the
# admin listener is not started at all. The admin BFF must send
# ADMIN_INTERNAL_TOKEN as the `x-internal-token` header on every request.
#
# ADMIN_BIND_ADDR is optional and app_env-gated when left unset: APP_ENV=dev
# binds 0.0.0.0 (so a Windows BFF can reach the WSL listener via localhost
# forwarding), any other env binds 127.0.0.1 (loopback only). Set it explicitly
# to override — e.g. a private/Tailscale IP in prod. Never expose it publicly.
# ADMIN_BIND_ADDR=
ADMIN_PORT=8081
# Dev/test token only — generate a fresh one for prod, e.g. `openssl rand -hex 32`.
# Must match ADMIN_INTERNAL_TOKEN in the sitwego-admin BFF's .env.local.
ADMIN_INTERNAL_TOKEN=dev-admin-token-0123456789abcdef0123456789abcdef

# --- Driver referral programme ---
# Reward issued to the referrer when their referred driver is activated.
# Type: cash_credit (default; credits the driver wallet), subscription_days,
# or badge. Value is in the unit the type implies: KES for cash_credit, days
# for subscription_days (unused for badge). Both optional; defaults shown.
REFERRAL_REWARD_TYPE=cash_credit
REFERRAL_REWARD_VALUE=250
